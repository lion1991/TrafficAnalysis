{
  "interface": "eth1",
  "lan_interface": "enp2s0",
  "database": "traffic.db",
  "bpf": "",
  "snapshot_len": 262144,
  "promiscuous": true,
  "bucket_seconds": 60,
  "flush_seconds": 10,
  "live_seconds": 5,
  "local_networks": [
    "192.168.248.0/21"
  ],
